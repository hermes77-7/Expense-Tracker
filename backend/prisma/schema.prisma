generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            Int            @id @default(autoincrement())

  name          String

  email         String         @unique

  password      String

  createdAt     DateTime       @default(now())

  transactions  Transaction[]

  goals         SavingsGoal[]
}

model Transaction {
  id               Int       @id @default(autoincrement())

  title            String

  amount           Float

  transactionType  String

  category         String

  description      String?

  createdAt        DateTime  @default(now())

  updatedAt        DateTime  @updatedAt

  userId           Int

  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])

  @@index([transactionType])

  @@index([category])
}

model SavingsGoal {
  id                Int                  @id @default(autoincrement())
  name              String
  targetAmount      Float
  savedAmount       Float                @default(0)
  deadline          DateTime?
  status            String               @default("active")   // ← add this
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  userId            Int
  user              User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  contributions     GoalContribution[]

  @@index([userId])
}

model GoalContribution {
  id             Int            @id @default(autoincrement())
  amount         Float
  note           String?                                       // ← add this
  createdAt      DateTime       @default(now())
  goalId         Int
  goal           SavingsGoal    @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId])
}