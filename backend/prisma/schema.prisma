generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id           Int           @id @default(autoincrement())

  name         String

  email        String        @unique

  password     String

  createdAt    DateTime      @default(now())

  transactions Transaction[]

  goals        SavingsGoal[]
}

model Transaction {
  id              Int       @id @default(autoincrement())

  title           String

  amount          Float

  transactionType String

  category        String

  description     String?

  createdAt       DateTime  @default(now())

  userId          Int

  user            User      @relation(fields: [userId], references: [id])
}

model SavingsGoal {
  id               Int                 @id @default(autoincrement())

  name             String

  targetAmount     Float

  savedAmount      Float               @default(0)

  deadline         DateTime?

  createdAt        DateTime            @default(now())

  userId           Int

  user             User                @relation(fields: [userId], references: [id])

  contributions    GoalContribution[]
}

model GoalContribution {
  id            Int           @id @default(autoincrement())

  amount        Float

  createdAt     DateTime      @default(now())

  goalId        Int

  goal          SavingsGoal   @relation(fields: [goalId], references: [id])
}